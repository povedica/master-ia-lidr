# Same keys as local runs. Docker Compose loads this file via `env_file: .env` — copy to `.env` and fill values; never commit `.env`.
LLM_PROVIDERS=openai,anthropic
STATIC_FALLBACK_ENABLED=true
LLM_AUTH_FALLBACK=false
LLM_DOMAIN_GUARDRAIL_ENABLED=true
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=30
# LiteLLM: optional logging label only (not credentials).
DEFAULT_LLM_PROVIDER=unset
# LiteLLM default model id documented for operators (`provider/model`). Runtime calls use prefixed OPENAI_MODEL / ANTHROPIC_MODEL unless you override with a prefixed value there.
DEFAULT_LLM_MODEL=openai/gpt-4o-mini
# Optional Gemini (Google AI); required only when routing to gemini/* models via future config.
GEMINI_API_KEY=
APP_ENV=local
# Comma-separated origins for browser UIs (Vite dev server). Do not use * in production defaults.
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Internal-only frontend route gate for /debug/retrieval. Compose bakes this into the web image at build time.
VITE_ENABLE_RETRIEVAL_DEBUG=false
DEV_MODE=false
LOG_LEVEL=INFO
ANTHROPIC_API_KEY=
# Current low-latency Haiku (3.5 Haiku ids were retired in 2026). Override if needed: claude-3-haiku-20240307
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_TIMEOUT_SECONDS=30
# Optional: Messages API ``anthropic-version`` header for ``dev-tools/anthropic_api_ping.py`` only; app uses the SDK default.
ANTHROPIC_API_VERSION=
# Max completion output tokens for estimation calls (OpenAI max_completion_tokens, Anthropic max_tokens).
ESTIMATION_OUTPUT_TOKENS_MAX=2048
# Persist successful 200 estimation outputs into output-responses/response-YYYYmmdd-hhmmss.md.
ESTIMATION_OUTPUT_PERSIST_ENABLED=false
# Persist every LLM provider call (request + response JSON) into output-responses/llm-call-YYYYmmdd-HHMMSS-NNN.json.
LLM_CALL_PERSIST_ENABLED=false
# Append per-request metadata (no estimation body) as NDJSON for analytics: output-stats/estimation-stats.jsonl
ESTIMATION_STATS_LOG_ENABLED=false
# Optional absolute path; when empty, uses repo-root output-stats/estimation-stats.jsonl
ESTIMATION_STATS_LOG_PATH=
# Session attachments (simplified submit): decoded file cap and prompt injection budget
MAX_ATTACHMENT_SIZE_BYTES=10485760
MAX_ATTACHMENT_CONTEXT_CHARS=131072
ALLOWED_ATTACHMENT_MIME_TYPES=text/plain,text/markdown,application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document
# Request JSON (not env): "evaluate" defaults true (estimator-style structural score); set false to omit score/validation; "preprocessing": none|inline_cleaning|two_phase
# Structured v2: bounded retries when the model JSON fails Pydantic validation (Instructor + LiteLLM).
STRUCTURED_OUTPUT_MAX_ATTEMPTS=3
# Optional: override prompt bundle directory name under app/prompts/estimation/ (default v1).
# Empty = estimation/v2 (default). Set v1 only to pin the retrocompatible bundle copy.
PROMPT_ESTIMATION_VERSION=
# Guardrails (feature 012): optional rules version label for cache/pipeline metadata (empty = registry default).
GUARDRAIL_RULES_VERSION=
# Minimum confidence (0-1) for structured v2 output before semantic downgrade.
ESTIMATION_MIN_OUTPUT_CONFIDENCE=0.05
# Optional per-guardrail rollout overrides: disabled | log_only | enforce (empty = use registry defaults).
GUARDRAIL_ROLLOUT_PII_BASIC=
GUARDRAIL_ROLLOUT_PROMPT_INJECTION_PATTERNS=
GUARDRAIL_ROLLOUT_ESTIMATION_DOMAIN_RELEVANCE=
GUARDRAIL_ROLLOUT_MODERATION_TOXICITY=
GUARDRAIL_ROLLOUT_OUTPUT_CONFIDENCE_FLOOR=
GUARDRAIL_ROLLOUT_OUTPUT_SENSITIVE_LEAKAGE=
GUARDRAIL_ROLLOUT_OUTPUT_USELESS_PLACEHOLDER=
# Semantic cache (feature 013): optional reuse of validated v2 responses (see docs/technical/README.md).
SEMANTIC_CACHE_ENABLED=false
SEMANTIC_CACHE_LOG_ONLY=true
# Empty = no Redis store unless SEMANTIC_CACHE_USE_MEMORY_STORE=true.
# With repo Docker Compose (`redis` service): redis://redis:6379/0 from containers; redis://127.0.0.1:6379/0 from host-only API.
# When set and SEMANTIC_CACHE_USE_MEMORY_STORE=false, the app uses the Redis Stack / RediSearch vector adapter.
SEMANTIC_CACHE_REDIS_URL=
SEMANTIC_CACHE_NAMESPACE=semantic:estimation
SEMANTIC_CACHE_TTL_SECONDS=86400
SEMANTIC_CACHE_SIMILARITY_THRESHOLD=0.92
SEMANTIC_CACHE_MAX_CANDIDATES=5
SEMANTIC_CACHE_EMBEDDING_PROVIDER=openai
SEMANTIC_CACHE_EMBEDDING_MODEL=text-embedding-3-small
SEMANTIC_CACHE_EMBEDDING_MODEL_VERSION=text-embedding-3-small:default
SEMANTIC_CACHE_EMBEDDING_TIMEOUT_SECONDS=10
SEMANTIC_CACHE_MAX_PAYLOAD_BYTES=262144
SEMANTIC_CACHE_ENABLED_ENDPOINTS=api_v2_estimate
SEMANTIC_CACHE_ENABLED_TENANTS=
SEMANTIC_CACHE_ENABLED_OPERATIONS=estimation_v2
SEMANTIC_CACHE_CACHE_SCHEMA_VERSION=1
# Single-process in-memory vector store for local tests (do not use in multi-worker production).
SEMANTIC_CACHE_USE_MEMORY_STORE=false
# Observability (feature 014): Langfuse Cloud EU + OTEL-based Python SDK (see docs/work-items/feature-014-langfuse-observability-analytics.md).
OTEL_EXPORT_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
OTEL_SERVICE_NAME=estimator-local
APP_VERSION=0.0.0-local
APP_RELEASE=local
LANGFUSE_DEBUG=false
LANGFUSE_SAMPLE_RATE=0.0
LANGFUSE_CAPTURE_INPUTS=false
LANGFUSE_CAPTURE_OUTPUTS=false
LANGFUSE_CAPTURE_USAGE=true
LANGFUSE_CAPTURE_COST=true
# Session integration tests (tests/test_sessions_integration.py): default uses FakeStructuredLLM (no network).
# Optional model override for the harness (empty = OPENAI_MODEL). Recorded on fake calls as litellm_model when faked.
SESSION_INTEGRATION_TEST_LLM_MODEL=
# When true, calls the real structured LLM (OPENAI_API_KEY required); deterministic fake-based tests are skipped.
SESSION_INTEGRATION_TEST_USE_REAL_LLM=false
# Actor-Critic-Boss orchestration (feature-026)
ACB_ENABLED=false
ACB_ENABLED_ENDPOINTS=session_estimate
ACB_MAX_ITERATIONS=2
ACB_ALLOW_SYNTHESIZE=true
ACB_BLOCKING_SEVERITIES=critical,major
ACB_FORCE_ENABLED_IN_DEV=false
ACB_CRITIC_MODEL=
ACB_BOSS_MODEL=
ACB_PROMPT_VERSION=v1
# Embedding pipeline (feature-032): OpenAI embedder for budget ingest (Session 07).
# Uses OPENAI_API_KEY and OPENAI_TIMEOUT_SECONDS; isolated from semantic cache settings.
EMBEDDING_PIPELINE_MODEL=text-embedding-3-small
EMBEDDING_PIPELINE_BATCH_SIZE=100
# Semantic search persistence (feature-036): Postgres via Docker Compose `postgres` service.
# From containers: postgresql+asyncpg://estimator:estimator@postgres:5432/estimator
# From host-only API: postgresql+asyncpg://estimator:estimator@127.0.0.1:5432/estimator
DATABASE_URL=
# Production retrieval modes (feature-050): A vector, B hybrid RRF, C vector+rerank, D hybrid+rerank.
RETRIEVAL_DEFAULT_MODE=A
RETRIEVAL_LEXICAL_TEXT_SEARCH_CONFIG=spanish
RETRIEVAL_RECALL_K=50
RETRIEVAL_TOP_K_FINAL=5
RETRIEVAL_RRF_K=60
RETRIEVAL_RERANK_ENABLED=false
RETRIEVAL_RERANK_MODEL=
# Grounded RAG estimation (feature-052)
RAG_ESTIMATION_RETRIEVAL_MODE=B
# RAGAS offline generation eval (dev/slow only)
RAGAS_JUDGE_MODEL=gpt-4o-mini
RAGAS_EMBEDDING_MODEL=text-embedding-3-small
# Base URL for query_examples.py (Compose sets http://app:8000 on the app service).
API_BASE_URL=http://127.0.0.1:8000
# Session estimation evals (tests/evals/): separate from SESSION_INTEGRATION_TEST_* above.
# Hard deterministic evals use FakeStructuredLLM and need no keys.
EVAL_ESTIMATOR_USE_REAL_LLM=false
EVAL_ESTIMATOR_MODEL=
EVAL_SOFT_CONSISTENCY_RUNS=3
EVAL_JUDGE_PROVIDER=openai
EVAL_JUDGE_MODEL=gpt-4o-mini
EVAL_JUDGE_API_KEY=
EVAL_JUDGE_THRESHOLD_MODE=warn
