# Same keys as local runs. Docker Compose loads this file via `env_file: .env` — copy to `.env` and fill values; never commit `.env`.
LLM_PROVIDERS=openai,anthropic
STATIC_FALLBACK_ENABLED=true
LLM_AUTH_FALLBACK=false
LLM_DOMAIN_GUARDRAIL_ENABLED=true
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=30
# LiteLLM: optional logging label only (not credentials).
DEFAULT_LLM_PROVIDER=unset
# LiteLLM default model id documented for operators (`provider/model`). Runtime calls use prefixed OPENAI_MODEL / ANTHROPIC_MODEL unless you override with a prefixed value there.
DEFAULT_LLM_MODEL=openai/gpt-4o-mini
# Optional Gemini (Google AI); required only when routing to gemini/* models via future config.
GEMINI_API_KEY=
APP_ENV=local
# Comma-separated origins for browser UIs (Vite dev server). Do not use * in production defaults.
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DEV_MODE=false
LOG_LEVEL=INFO
ANTHROPIC_API_KEY=
# Current low-latency Haiku (3.5 Haiku ids were retired in 2026). Override if needed: claude-3-haiku-20240307
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_TIMEOUT_SECONDS=30
# Optional: Messages API ``anthropic-version`` header for ``dev-tools/anthropic_api_ping.py`` only; app uses the SDK default.
ANTHROPIC_API_VERSION=
# Per estimation mode: max completion output tokens (OpenAI max_completion_tokens, Anthropic max_tokens).
ESTIMATION_BASIC_OUTPUT_TOKENS_MAX=1024
ESTIMATION_STANDARD_OUTPUT_TOKENS_MAX=2048
ESTIMATION_PROFESSIONAL_OUTPUT_TOKENS_MAX=4096
ESTIMATION_EXPERT_REVIEW_OUTPUT_TOKENS_MAX=8192
# Optional: force prompt/output profile (basic | standard | professional | expert_review).
# Leave empty for adaptive routing from input quality.
FORCED_ESTIMATION_MODE=
# Persist successful 200 estimation outputs into output-responses/response-YYYYmmdd-hhmmss.md.
ESTIMATION_OUTPUT_PERSIST_ENABLED=false
# Append per-request metadata (no estimation body) as NDJSON for analytics: output-stats/estimation-stats.jsonl
ESTIMATION_STATS_LOG_ENABLED=false
# Optional absolute path; when empty, uses repo-root output-stats/estimation-stats.jsonl
ESTIMATION_STATS_LOG_PATH=
# Request JSON (not env): "evaluate" defaults true (estimator-style structural score); set false to omit score/validation; "preprocessing": none|inline_cleaning|two_phase
# Streamlit: default FastAPI base URL in the sidebar. Local runs on the host: http://127.0.0.1:8000.
# Docker Compose (streamlit service): default is http://host.docker.internal:8000 (API published on host :8000).
#ESTIMATOR_API_BASE_URL=http://127.0.0.1:8000
